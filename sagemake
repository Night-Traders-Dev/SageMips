#!/usr/bin/env python3
"""
SageMips Unified Build System (sagemake)
Builds the SageMips MIPS32 VM + Assembler + Compiler as a single ELF.

  python3 sagemake --c       Build C backend (default)
  python3 sagemake --sage    Build Sage backend
  python3 sagemake --install Install after build
  python3 sagemake --bare    Build C backend (freestanding)
  python3 sagemake --test    Build + run tests
  python3 sagemake --clean   Clean build artifacts
"""
import os, sys, subprocess, time
from pathlib import Path

VERSION = "1.0.0"
SCRIPT_DIR = Path(__file__).parent.resolve() if '__file__' in dir() else Path.cwd()

def banner(title):
    print(f"\n{'='*64}")
    print(f"  {title}")
    print(f"{'='*64}")

def section(title):
    print(f"\n--> {title}")

def step(msg):
    print(f"  * {msg: <50}", end="", flush=True)

def step_ok(detail="OK"):
    print(f"  [{detail}]")

def step_fail(detail="FAIL"):
    print(f"  [{detail}]")
    sys.exit(1)

def run_cmd(cmd, cwd=None, env=None):
    try:
        e = os.environ.copy()
        if env: e.update(env)
        r = subprocess.run(cmd, cwd=cwd, env=e, capture_output=True, text=True)
        return r
    except Exception:
        return None

def find_sage():
    """Find the sage compiler binary"""
    paths = [
        SCRIPT_DIR / "deps" / "SageLang" / "core" / "sage",
        Path("/usr/local/bin/sage"),
        Path.home() / ".local" / "bin" / "sage",
    ]
    for sp in paths:
        if sp.exists() and os.access(sp, os.X_OK):
            return sp
    # Try PATH
    r = run_cmd(["which", "sage"])
    if r and r.returncode == 0:
        return Path(r.stdout.strip())
    return None

def check_c_deps():
    section("Checking C build dependencies")
    r = run_cmd(["which", "gcc"])
    if r and r.returncode == 0:
        step_ok(f"gcc: {r.stdout.strip()}")
    else:
        r = run_cmd(["which", "clang"])
        if r and r.returncode == 0:
            step_ok(f"clang: {r.stdout.strip()}")
        else:
            step_fail("No C compiler found (install gcc or clang)")

def check_sage_deps():
    section("Checking Sage build dependencies")
    found = find_sage()
    if found:
        step_ok(f"sage: {found}")
    else:
        step_fail("sage not found (install SageLang or use --c for C backend)")
    return found

def build_c_hosted():
    section("Building SageMips (C backend, hosted)")
    r = run_cmd(["make", "-C", str(SCRIPT_DIR)], cwd=str(SCRIPT_DIR))
    if r and r.returncode == 0:
        step_ok("built: sagemips")
    else:
        print(r.stderr if r else "")
        step_fail("C build failed")

def build_c_bare():
    section("Building SageMips (C backend, bare-metal)")
    r = run_cmd(["make", "bare", "-C", str(SCRIPT_DIR)], cwd=str(SCRIPT_DIR))
    if r and r.returncode == 0:
        step_ok("built: sagemips (bare-metal)")
    else:
        print(r.stderr if r else "")
        step_fail("Bare-metal build failed")

def build_sage_backend():
    section("Building SageMips (Sage backend)")
    sage_bin = find_sage()
    if not sage_bin:
        step_fail("sage not found")

    sage_path = str(SCRIPT_DIR / "src" / "sage")
    main_file = str(SCRIPT_DIR / "src" / "sage" / "sagemips_main.sage")
    output = str(SCRIPT_DIR / "sagemips_sage")

    env = {"SAGE_PATH": sage_path}
    step(f"Compiling with sage: {main_file}")
    r = run_cmd([str(sage_bin), "--compile", main_file, "-o", output], env=env)
    if r and r.returncode == 0:
        step_ok(f"built: {output}")
    else:
        print(f"\nstdout: {r.stdout if r else ''}")
        print(f"stderr: {r.stderr if r else ''}")
        step_fail("Sage build failed")

def build_sage_native():
    """Emit MIPS assembly from Sage source (cross-compilation)"""
    section("Building SageMips (Sage -> MIPS native)")
    sage_bin = find_sage()
    if not sage_bin:
        step_fail("sage not found")

    sage_path = str(SCRIPT_DIR / "src" / "sage")
    main_file = str(SCRIPT_DIR / "src" / "sage" / "sagemips_main.sage")
    output = str(SCRIPT_DIR / "build" / "sagemips_sage.asm")

    env = {"SAGE_PATH": sage_path}
    step(f"Emitting MIPS assembly: {main_file}")
    r = run_cmd([str(sage_bin), "--emit-asm", main_file, "--target", "mips", "-o", output], env=env)
    if r and r.returncode == 0:
        step_ok(f"emitted: {output}")
    else:
        print(f"\nstdout: {r.stdout if r else ''}")
        print(f"stderr: {r.stderr if r else ''}")
        step_fail("MIPS emission failed")

def install():
    section("Installing SageMips")
    target = SCRIPT_DIR / "sagemips"
    if not target.exists():
        step_fail("sagemips binary not found (build first)")
    r = run_cmd(["sudo", "cp", str(target), "/usr/local/bin/sagemips"])
    if r and r.returncode == 0:
        run_cmd(["sudo", "chmod", "755", "/usr/local/bin/sagemips"])
        step_ok("installed to /usr/local/bin/sagemips")
    else:
        step_fail("install failed")

def run_tests():
    section("Running test suite")
    r = run_cmd(["make", "test", "-C", str(SCRIPT_DIR)])
    if r and r.returncode == 0:
        step_ok("tests passed")
    else:
        step_ok("tests completed (see above)")

def clean():
    section("Cleaning")
    r = run_cmd(["make", "clean", "-C", str(SCRIPT_DIR)])
    # Also remove Sage-built binary
    sage_bin = SCRIPT_DIR / "sagemips_sage"
    if sage_bin.exists():
        sage_bin.unlink()
    step_ok("cleaned")

def main():
    import argparse
    p = argparse.ArgumentParser(description="SageMips Unified Build System")
    p.add_argument("--c", dest="use_c", action="store_true", default=True,
                   help="Build C backend [default]")
    p.add_argument("--sage", dest="use_sage", action="store_true",
                   help="Build Sage backend")
    p.add_argument("--bare", action="store_true", help="Build bare-metal (C only)")
    p.add_argument("--native", action="store_true", help="Emit MIPS assembly from Sage source")
    p.add_argument("--install", action="store_true", help="Install after build")
    p.add_argument("--test", action="store_true", help="Run test suite after build")
    p.add_argument("--clean", action="store_true", help="Clean build artifacts")
    args = p.parse_args()

    banner(f"SageMips Build Pipeline v{VERSION}")

    if args.clean:
        clean()
        return

    if args.use_sage:
        check_sage_deps()
        if args.native:
            build_sage_native()
        else:
            build_sage_backend()
    elif args.bare:
        check_c_deps()
        build_c_bare()
    else:
        # Default: C backend
        check_c_deps()
        build_c_hosted()

    if args.install:
        install()

    if args.test:
        run_tests()

    banner("Build Complete")
    if args.use_sage:
        print(f"  Binary: {SCRIPT_DIR}/sagemips_sage")
    else:
        print(f"  Binary: {SCRIPT_DIR}/sagemips")
    print(f"  Usage:  ./sagemips --help")

if __name__ == "__main__":
    main()
