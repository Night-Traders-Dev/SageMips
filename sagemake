#!/usr/bin/env python3
"""
SageMips Unified Build System (sagemake)
Builds the SageMips MIPS32 VM + Assembler + Compiler as a single ELF.
"""
import os, sys, subprocess, time, shutil
from pathlib import Path

VERSION = "1.0.0"
SCRIPT_DIR = Path(__file__).parent.resolve() if '__file__' in dir() else Path.cwd()

def banner(title):
    print(f"\n{'='*64}")
    print(f"  {title}")
    print(f"{'='*64}")

def section(title):
    print(f"\n--> {title}")

def step(msg):
    print(f"  * {msg: <50}", end="", flush=True)

def step_ok(detail="OK"):
    print(f"  [{detail}]")

def step_fail(detail="FAIL"):
    print(f"  [{detail}]")
    sys.exit(1)

def run_cmd(cmd, cwd=None, env=None):
    try:
        e = os.environ.copy()
        if env: e.update(env)
        r = subprocess.run(cmd, cwd=cwd, env=e, capture_output=True, text=True)
        return r
    except Exception as ex:
        return None

def check_deps():
    section("Checking dependencies")
    step("Checking for cc (gcc/clang)")
    r = run_cmd(["which", "gcc"])
    if r and r.returncode == 0:
        step_ok("gcc found")
    else:
        r = run_cmd(["which", "clang"])
        if r and r.returncode == 0:
            step_ok("clang found")
        else:
            step_fail("No C compiler found")

    step("Checking for sage")
    sage_paths = [
        SCRIPT_DIR / "deps" / "SageLang" / "core" / "sage",
        Path("/usr/local/bin/sage"),
        Path.home() / ".local" / "bin" / "sage",
    ]
    found_sage = None
    for sp in sage_paths:
        if sp.exists() and os.access(sp, os.X_OK):
            found_sage = sp
            break
    if found_sage:
        step_ok(f"sage found: {found_sage}")
    else:
        step_ok("sage not found (cross-compilation will use cc only)")

    return found_sage

def build_hosted():
    section("Building SageMips (hosted)")
    r = run_cmd(["make", "-C", str(SCRIPT_DIR)], cwd=str(SCRIPT_DIR))
    if r and r.returncode == 0:
        step_ok("build complete")
    else:
        if r:
            print(r.stderr)
        step_fail("Build failed")

def build_bare():
    section("Building SageMips (bare-metal)")
    r = run_cmd(["make", "bare", "-C", str(SCRIPT_DIR)], cwd=str(SCRIPT_DIR))
    if r and r.returncode == 0:
        step_ok("bare-metal build complete")
    else:
        if r:
            print(r.stderr)
        step_fail("Bare-metal build failed")

def build_sage():
    section("Bootstrapping SageLang")
    sage_path = SCRIPT_DIR / "deps" / "SageLang" / "core"
    if not (sage_path / "Makefile").exists():
        step("Skipping (SageLang not in deps)")
        step_ok()
        return None

    if (sage_path / "sage").exists():
        step("Using existing sage binary")
        step_ok()
        return sage_path / "sage"

    step("Compiling SageLang core")
    start = time.time()
    r = run_cmd(
        ["make", "-j", str(os.cpu_count() or 2)],
        cwd=str(sage_path),
        env={"LDFLAGS": "-lm -lpthread -ldl"}
    )
    if r and r.returncode == 0:
        elapsed = int(time.time() - start)
        step_ok(f"{elapsed}s")
    else:
        if r:
            print(f"\nstderr: {r.stderr[:500]}")
        step_fail("SageLang build failed")
    return sage_path / "sage"

def install():
    section("Installing SageMips")
    target = SCRIPT_DIR / "sagemips"
    if not target.exists():
        step_fail("sagemips binary not found (run build first)")

    step("Copying to /usr/local/bin")
    r = run_cmd(["sudo", "cp", str(target), "/usr/local/bin/sagemips"])
    if r and r.returncode == 0:
        run_cmd(["sudo", "chmod", "755", "/usr/local/bin/sagemips"])
        step_ok("installed")
    else:
        step_fail("install failed")

def run_tests():
    section("Running tests")
    r = run_cmd(["make", "test", "-C", str(SCRIPT_DIR)], cwd=str(SCRIPT_DIR))
    if r and r.returncode == 0:
        step_ok("all tests passed")
    else:
        step_ok("some tests may have failed (see above)")

def main():
    import argparse
    p = argparse.ArgumentParser(description="SageMips Unified Build System")
    p.add_argument("command", nargs="?", default="build", help="build, bare, install, test, clean, help")
    p.add_argument("--install", action="store_true", help="Install after build")
    args = p.parse_args()

    banner(f"SageMips Build Pipeline v{VERSION}")

    if args.command == "help":
        print("Commands: build [default], bare, install, test, clean, help")
        return

    if args.command == "clean":
        run_cmd(["make", "clean", "-C", str(SCRIPT_DIR)])
        return

    if args.command == "install":
        install()
        return

    if args.command == "test":
        check_deps()
        build_hosted()
        run_tests()
        return

    if args.command == "bare":
        check_deps()
        build_sage()
        build_bare()
        return

    # Default: build
    check_deps()
    build_sage()
    build_hosted()

    if args.install:
        install()

    banner("Build Complete")
    print(f"  Binary: {SCRIPT_DIR}/sagemips")
    print(f"  Usage:  ./sagemips --help")

if __name__ == "__main__":
    main()
